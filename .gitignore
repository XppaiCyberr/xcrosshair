## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file is a combination of standard .NET ignore patterns
## and project-specific ignores for xcrosshair.

# Build results
[Bb]in/
[Oo]bj/
[Rr]elease/
[Dd]ebug/

# Publish directories
publish/
publish_local/
publish_final/

# Logs
*.log
output.txt

# Project-specific ignores
ss.png

# Visual Studio
.vs/
.vscode/
*.user
*.suo
*.userosscache
*.sln.docstates
*.opendb
*.db
*.VC.db

# Rider / JetBrains
.idea/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono Auto Generated Files
mono_crash.*

# NuGet
*.nupkg
# The packages folder can be ignored because of Package Restore
**/packages/*
# except build/, which is used as an MSBuild target.
!**/packages/build/
# Uncomment if using NuGet packages
# packages/

# Windows image cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on secondary drives
$RECYCLE.BIN/
