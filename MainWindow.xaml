<Window x:Class="xcrosshair.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="xcrosshair" 
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Loaded="Window_Loaded">
    <Window.Resources>
        <!-- Dark Theme Colors -->
        <Color x:Key="BackgroundColor">#1E1E1E</Color>
        <Color x:Key="BorderColor">#333333</Color>
        <Color x:Key="AccentColor">#007ACC</Color>
        <Color x:Key="TextColor">#CCCCCC</Color>
        <Color x:Key="HeaderTextColor">#FFFFFF</Color>

        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
        <SolidColorBrush x:Key="HeaderTextBrush" Color="{StaticResource HeaderTextColor}" />

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#3F3F46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3E3E42" />
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
            </Style.Resources>
        </Style>

        <!-- Slider Style -->
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,5" />
        </Style>

        <!-- Label Style -->
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#999999" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,10,0,2" />
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Crosshair Container -->
        <Canvas x:Name="CrosshairCanvas" IsHitTestVisible="False">
            <!-- Simple Crosshair (Default) -->
            <Rectangle x:Name="HorizontalLine" Fill="Lime" Width="20" Height="2" Visibility="Visible" />
            <Rectangle x:Name="VerticalLine" Fill="Lime" Width="2" Height="20" Visibility="Visible" />

            <!-- VALORANT Crosshair Elements -->
            <Rectangle x:Name="CenterDotOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="CenterDot" Fill="White" Visibility="Collapsed" />

            <!-- Inner Lines Outlines -->
            <Rectangle x:Name="InnerLeftOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="InnerRightOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="InnerTopOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="InnerBottomOutline" Fill="Black" Visibility="Collapsed" />

            <!-- Inner Lines -->
            <Rectangle x:Name="InnerLeft" Fill="White" Visibility="Collapsed" />
            <Rectangle x:Name="InnerRight" Fill="White" Visibility="Collapsed" />
            <Rectangle x:Name="InnerTop" Fill="White" Visibility="Collapsed" />
            <Rectangle x:Name="InnerBottom" Fill="White" Visibility="Collapsed" />

            <!-- Outer Lines Outlines -->
            <Rectangle x:Name="OuterLeftOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="OuterRightOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="OuterTopOutline" Fill="Black" Visibility="Collapsed" />
            <Rectangle x:Name="OuterBottomOutline" Fill="Black" Visibility="Collapsed" />

            <!-- Outer Lines -->
            <Rectangle x:Name="OuterLeft" Fill="White" Visibility="Collapsed" />
            <Rectangle x:Name="OuterRight" Fill="White" Visibility="Collapsed" />
            <Rectangle x:Name="OuterTop" Fill="White" Visibility="Collapsed" />
            <Rectangle x:Name="OuterBottom" Fill="White" Visibility="Collapsed" />
        </Canvas>

        <!-- Settings Menu -->
        <Border x:Name="SettingsMenu" 
                Visibility="Collapsed"
                Width="260" 
                Background="#E61E1E1E" 
                BorderBrush="#444444" 
                BorderThickness="1" 
                CornerRadius="8"
                VerticalAlignment="Top" 
                HorizontalAlignment="Right"
                Margin="20"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.5" ShadowDepth="0"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="SETTINGS" 
                           Foreground="White" 
                           FontSize="14"
                           FontWeight="Bold" 
                           Margin="0,0,0,15" 
                           HorizontalAlignment="Center"/>

                <TabControl Background="Transparent" BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" BorderThickness="0,0,0,2" Margin="0,0,10,5">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="5,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC" />
                                                <Setter Property="Foreground" Value="White" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="False">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="Transparent" />
                                                <Setter Property="Foreground" Value="#888888" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    
                    <!-- General Settings -->
                    <TabItem Header="GENERAL">
                        <StackPanel>
                            <!-- Monitor Selection -->
                            <TextBlock Text="MONITOR" Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="MonitorComboBox" SelectionChanged="MonitorComboBox_SelectionChanged"/>

                            <!-- Menu Position -->
                            <TextBlock Text="MENU POSITION" Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="PositionComboBox" SelectionChanged="PositionComboBox_SelectionChanged">
                                <ComboBoxItem Content="Top Right" Tag="TopRight" IsSelected="True"/>
                                <ComboBoxItem Content="Top Left" Tag="TopLeft"/>
                                <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                                <ComboBoxItem Content="Bottom Left" Tag="BottomLeft"/>
                                <ComboBoxItem Content="Center" Tag="Center"/>
                            </ComboBox>

                            <!-- Color -->
                            <TextBlock Text="CROSSHAIR COLOR" Style="{StaticResource SettingLabel}"/>
                            <ComboBox x:Name="ColorComboBox" SelectionChanged="ColorComboBox_SelectionChanged">
                                <ComboBoxItem Content="Lime" Tag="Lime" IsSelected="True"/>
                                <ComboBoxItem Content="Red" Tag="Red"/>
                                <ComboBoxItem Content="Cyan" Tag="Cyan"/>
                                <ComboBoxItem Content="White" Tag="White"/>
                                <ComboBoxItem Content="Yellow" Tag="Yellow"/>
                                <ComboBoxItem Content="Orange" Tag="Orange"/>
                                <ComboBoxItem Content="Blue" Tag="Blue"/>
                                <ComboBoxItem Content="Pink" Tag="Pink"/>
                                <ComboBoxItem Content="Purple" Tag="Purple"/>
                                <ComboBoxItem Content="Custom..." Tag="Custom"/>
                            </ComboBox>

                            <!-- Size -->
                            <DockPanel Margin="0,10,0,0">
                                <TextBlock Text="SIZE" Style="{StaticResource SettingLabel}" DockPanel.Dock="Left" Margin="0"/>
                                <TextBlock x:Name="SizeLabel" Text="20" Foreground="White" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </DockPanel>
                            <Slider x:Name="SizeSlider" Minimum="2" Maximum="100" Value="20" ValueChanged="SettingsChanged"/>

                            <!-- Thickness -->
                            <DockPanel Margin="0,5,0,0">
                                <TextBlock Text="THICKNESS" Style="{StaticResource SettingLabel}" DockPanel.Dock="Left" Margin="0"/>
                                <TextBlock x:Name="ThicknessLabel" Text="2" Foreground="White" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </DockPanel>
                            <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="10" Value="2" ValueChanged="SettingsChanged"/>
                        </StackPanel>
                    </TabItem>

                    <!-- VALORANT Settings -->
                    <TabItem Header="VALORANT">
                        <StackPanel>
                            <TextBlock Text="PROFILE CODE" Style="{StaticResource SettingLabel}"/>
                            <TextBox x:Name="ValorantCodeBox" 
                                     Background="#2D2D30" 
                                     Foreground="White" 
                                     BorderBrush="#3F3F46" 
                                     Padding="5" 
                                     Height="60" 
                                     TextWrapping="Wrap" 
                                     AcceptsReturn="True" 
                                     FontSize="10"/>
                            
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Import" Click="ImportValorantCode_Click" Margin="0,0,5,0" Height="28"/>
                                <Button Grid.Column="1" Content="Clear" Click="ClearValorantCode_Click" Margin="5,0,0,0" Height="28"/>
                            </Grid>
                            
                            <Button Content="Copy Current Code" Click="CopyValorantCode_Click" Margin="0,10,0,0" Height="28"/>
                            
                            <TextBlock Text="Note: Overrides general settings" 
                                       Foreground="#666666" 
                                       FontSize="9" 
                                       Margin="0,10,0,0" 
                                       HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <!-- Actions -->
                <Button Content="Exit Application" 
                        Background="#442222" 
                        Foreground="White" 
                        BorderThickness="1" 
                        BorderBrush="#663333"
                        Height="32"
                        Margin="0,20,0,0" 
                        Click="ExitButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="Press [Home] to Hide Menu" 
                           Foreground="#666666" 
                           FontSize="10" 
                           Margin="0,15,0,0" 
                           HorizontalAlignment="Center"
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
